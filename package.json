{
  "name": "spotify-lyrics",
  "productName": "Spotify Lyrics",
  "version": "1.0.1",
  "description": "A synced-lyrics overlay for Spotify. Shows the current song and scrolls its lyrics in time, in a small always-on-top mini-player.",
  "author": "Carlos Hernandez (Carlos-H101)",
  "license": "MIT",
  "main": "app/main.js",
  "homepage": "https://splyrics.com",
  "repository": { "type": "git", "url": "https://github.com/Carlos-H101/spotify-lyrics.git" },
  "scripts": {
    "start": "electron app",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "42.3.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.carlosh101.spotifylyrics",
    "productName": "Spotify Lyrics",
    "copyright": "Copyright © 2026 Carlos Hernandez",
    "directories": { "app": "app", "output": "dist" },
    "asarUnpack": ["assets/**"],
    "win": {
      "target": ["nsis"],
      "artifactName": "Spotify-Lyrics-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spotify Lyrics"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.music",
      "artifactName": "Spotify-Lyrics-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "AudioVideo",
      "maintainer": "Carlos Hernandez <carlos-h101@users.noreply.github.com>",
      "artifactName": "Spotify-Lyrics-${arch}.${ext}"
    },
    "publish": [{ "provider": "github", "owner": "Carlos-H101", "repo": "spotify-lyrics", "releaseType": "release" }]
  }
}
